# Vorlage fuer orchestrator/.env  -- KEINE echten Werte hier eintragen.
# Kopiere diese Datei nach orchestrator/.env und trage echte Werte ein.
# orchestrator/.env ist per .gitignore ausgeschlossen und wird NIE committet.

# GATE B: Betrieb des Orchestrators selbst (Anthropic-Konto fuer HoA/Subagenten)
ANTHROPIC_API_KEY=

# Optionales Kostentracking (abschaltbar). Standard: aus (siehe config.toml).
AGENTOPS_API_KEY=

# Live-Voice-Kanal (CEO-Tor, kostenpflichtig). Erst am GATE eintragen.
# STT (Default Deepgram) + EIN TTS-Provider (Cartesia ODER ElevenLabs, siehe config.toml [voice]).
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# Telegram-Kanal (mobil). Bot via @BotFather erstellen -> Token hier eintragen.
# TELEGRAM_ALLOWED_CHAT_ID: nur diese Chat-ID wird bedient (Sicherheit); nach erstem /start setzen.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Investment (CIO, advisory -- keine Trades). Schalter fuer die autonomen Lese-Loops:
#   INVESTMENT_AUTO_SCREEN=1  -> werktags 16:00 Markt-Screen + Mo 09:00 Wochenprognose
#   INV_FEATURE_LOOP=1        -> taeglich 07:00 Merkmals-/Preis-Snapshot (Walk-Forward-Lern-Loop, braucht
#                               Supabase: SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY fuer die durable Zweitschrift)
#   INV_AUTO_TRADE=1          -> werktags 15:00 autonomer PAPER-Trade der Top-Chance gegen die Leitplanken
#                               (braucht INV_FEATURE_LOOP + Modus paper; autonom erst nach Track-Record-
#                               Freischaltung, sonst 1-Tap-Freigabe per Telegram). Kein echtes Geld.
INVESTMENT_AUTO_SCREEN=
INV_FEATURE_LOOP=
INV_AUTO_TRADE=

# Business-Keys fuer Integrationen kommen spaeter AUSSCHLIESSLICH ueber das
# Capability-Verfahren (grant_capability) -- nicht hier vorab eintragen.
